<?xml version="1.0"?>
<rdf:RDF xmlns="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#"
     xml:base="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project"
     xmlns:owl="http://www.w3.org/2002/07/owl#"
     xmlns:rdf="http://www.w3.org/1999/02/22-rdf-syntax-ns#"
     xmlns:xml="http://www.w3.org/XML/1998/namespace"
     xmlns:xsd="http://www.w3.org/2001/XMLSchema#"
     xmlns:rdfs="http://www.w3.org/2000/01/rdf-schema#">
    <owl:Ontology rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project"/>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Object Properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#canSee -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#canSee">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Piece"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Square"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#controlsCenterSquare -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#controlsCenterSquare"/>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#hasActivePiece -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#hasActivePiece">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BoardState"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Piece"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#hasDiagonal -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#hasDiagonal">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BoardState"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Diagonal"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#hasFile -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#hasFile">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BoardState"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#File"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#hasPiece -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#hasPiece">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#onSquare"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Square"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Piece"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#hasRank -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#hasRank">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BoardState"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Rank"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#hasSquare -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#hasSquare">
        <rdfs:range rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Square"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#isAttacking -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#isAttacking">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topObjectProperty"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#underAttack"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Piece"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Piece"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#isDefended -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#isDefended">
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#isDefending"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#isDefending -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#isDefending">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Piece"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Piece"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#isForking -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#isForking">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#isAttacking"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#isPawnBreakMove -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#isPawnBreakMove">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#legalMove"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#isPinned -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#isPinned">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#underAttack"/>
        <owl:inverseOf rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#isPinning"/>
        <rdfs:domain rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#PinnedPiece"/>
        <rdfs:range>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Piece"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#isAttacking"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#PinnedPiece"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:range>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#isPinning -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#isPinning">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#isAttacking"/>
        <rdfs:domain>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Piece"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#isAttacking"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#PinnedPiece"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:domain>
        <rdfs:range rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#PinnedPiece"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#legalMove -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#legalMove">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Piece"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#onSquare -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#onSquare">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Piece"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Square"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#threatening -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#threatening">
        <rdfs:subPropertyOf rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#isAttacking"/>
    </owl:ObjectProperty>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#underAttack -->

    <owl:ObjectProperty rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#underAttack">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Piece"/>
        <rdfs:range rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Piece"/>
    </owl:ObjectProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Data properties
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#isEmpty -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#isEmpty">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Square"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#boolean"/>
    </owl:DatatypeProperty>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#pointsWorth -->

    <owl:DatatypeProperty rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#pointsWorth">
        <rdfs:domain rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Piece"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#integer"/>
    </owl:DatatypeProperty>
    


    <!-- 
    ///////////////////////////////////////////////////////////////////////////////////////
    //
    // Classes
    //
    ///////////////////////////////////////////////////////////////////////////////////////
     -->

    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#AbsolutePinnedPiece -->

    <owl:Class rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#AbsolutePinnedPiece">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#PinnedPiece"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#ActivePiece -->

    <owl:Class rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#ActivePiece">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Piece"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#AnchoredBishop -->

    <owl:Class rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#AnchoredBishop">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Bishop"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#isDefended"/>
                        <owl:someValuesFrom rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Pawn"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BackwardPawn -->

    <owl:Class rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BackwardPawn">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Pawn"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BadBishop -->

    <owl:Class rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BadBishop">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Bishop"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Bishop -->

    <owl:Class rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Bishop">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Piece"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#pointsWorth"/>
                <owl:hasValue rdf:datatype="http://www.w3.org/2001/XMLSchema#integer">3</owl:hasValue>
            </owl:Restriction>
        </rdfs:subClassOf>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BlackAbsolutePinnedPiece -->

    <owl:Class rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BlackAbsolutePinnedPiece">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#AbsolutePinnedPiece"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BlackPiece"/>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#AbsolutePinnedPiece"/>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BlackDisadvantage"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BlackActivePiece -->

    <owl:Class rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BlackActivePiece">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#ActivePiece"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BlackPiece"/>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#ActivePiece"/>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BlackAdvantage"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BlackAdvantage -->

    <owl:Class rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BlackAdvantage">
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BlackState"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BlackBackwardPawn -->

    <owl:Class rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BlackBackwardPawn">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BackwardPawn"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BlackPiece"/>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BackwardPawn"/>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BlackDisadvantage"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BlackBishopPair -->

    <owl:Class rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BlackBishopPair">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#hasActivePiece"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BlackPiece"/>
                                    <rdf:Description rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#DarkBishop"/>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#hasActivePiece"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BlackPiece"/>
                                    <rdf:Description rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#LightBishop"/>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BlackState"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BlackCastledKing -->

    <owl:Class rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BlackCastledKing">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BlackPiece"/>
                    <rdf:Description rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#CastledKing"/>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BlackAdvantage"/>
    </owl:Class>
    


    <!-- http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BlackControlledDiagonal -->

    <owl:Class rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BlackControlledDiagonal">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#OpenDiagonal"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#hasSquare"/>
                        <owl:someValuesFrom>
                            <owl:Class>
                                <owl:intersectionOf rdf:parseType="Collection">
                                    <rdf:Description rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Square"/>
                                    <owl:Restriction>
                                        <owl:onProperty rdf:resource="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#hasPiece"/>
                                        <owl:someValuesFrom>
                                            <owl:Class>
                                                <owl:intersectionOf rdf:parseType="Collection">
                                                    <rdf:Description rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#BlackPiece"/>
                                                    <owl:Class>
                                                        <owl:unionOf rdf:parseType="Collection">
                                                            <rdf:Description rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Bishop"/>
                                                            <rdf:Description rdf:about="http://www.semanticweb.org/dawid/ontologies/2026/1/Bachelor_Project#Queen"/>
                                                        </owl:unionOf>
                                                    </owl:Class>
                                                </owl:intersectionOf>
                                            </owl:Class>
                                        </owl:someValuesFrom>
                                    </owl:Restriction>
                                </owl:intersectionOf>
                            </owl:Class>
                        </owl:someValuesFrom>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
